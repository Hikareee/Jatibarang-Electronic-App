# Google Gemini API Key (browser — AI Assistant / client features)
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_api_key_here

# RAB AI layer (server-only). Set in Vercel env or `vercel dev`; do not use VITE_ prefix.
GEMINI_API_KEY=your_api_key_here

# Optional: full API origin if the SPA is served from another host than /api
# VITE_AI_RAB_BASE_URL=https://your-deployment.vercel.app

# Optional: Vite dev proxy target (default http://127.0.0.1:3000 with `npx vercel dev`)
# VITE_DEV_API_PROXY=http://127.0.0.1:3000

# Supabase (Storage for payment proofs, etc.)
