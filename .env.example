# Google Gemini API Key (browser — AI Assistant / client features)
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_api_key_here

# RAB AI layer (server-only). Set in Vercel env or `vercel dev`; do not use VITE_ prefix.
GEMINI_API_KEY=your_api_key_here

# Optional: full API origin if the SPA is served from another host than /api
# VITE_AI_RAB_BASE_URL=https://your-deployment.vercel.app

# Optional: Vite dev proxy target (default http://127.0.0.1:3000 with `npx vercel dev`)
# VITE_DEV_API_PROXY=http://127.0.0.1:3000

# Firebase Web config (required)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
# optional (analytics)
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Auth behavior:
# false -> do NOT auto-create users/{uid} docs on login (recommended for migrated projects).
# true  -> preserve legacy behavior creating users docs from client.
VITE_AUTH_AUTO_PROVISION_USER_DOC=false

# Supabase (optional). Leave blank to disable Supabase paths safely.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Edge Function environment (do NOT expose SERVICE_ROLE in browser env)
# These are example names you will set for your deployed Edge Function via supabase secrets
# Run:
# supabase secrets set --env-file <(printf "SUPABASE_URL=%s\nSUPABASE_SERVICE_ROLE_KEY=%s\n" "https://idkznzsdqkqlopnltmac.supabase.co" "your_service_role_key_here")
# Never place the service role key in Vite (VITE_*) env or commit it to the repo.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
