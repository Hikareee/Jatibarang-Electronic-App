## Local development environment variables
## Copy to `.env.local` (do NOT commit `.env.local`)

# Firebase Admin credentials (recommended: paste the full service account JSON as one line)
# Example (minified JSON):
# FIREBASE_ADMIN_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}
FIREBASE_ADMIN_CREDENTIALS_JSON=

# OR split variables:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Bootstrap an initial owner (only needed the first time)
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_UID=

