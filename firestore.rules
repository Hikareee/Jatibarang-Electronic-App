rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isApproved() {
      return signedIn() && userDoc().exists() && userDoc().data.approved == true;
    }

    function role() {
      return isApproved() ? userDoc().data.role : 'employee';
    }

    function isOwner() {
      return role() == 'owner';
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isManager() {
      return role() == 'manager';
    }

    function isManagerLike() {
      return isOwner() || isAdmin() || isManager();
    }

    // ---- Users (roles live here) ----
    match /users/{uid} {
      allow read: if isApproved() && (uid == request.auth.uid || isManagerLike());

      // Only owner can create/update other users' role/approval.
      // (You can relax this if you want admins to manage users.)
      allow create: if isOwner();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    // ---- Contacts ----
    // NOTE: Firestore rules cannot hide individual fields inside a document.
    // If payroll/salary is stored in contacts, any role that can read contacts
    // can read those fields. Keep payroll data in owner-only collections.
    match /contacts/{contactId} {
      allow read: if isApproved(); // used throughout the app for pickers
      allow create, update, delete: if isManagerLike();
    }

    // ---- Payroll (owner-only) ----
    match /payrollRuns/{runId} {
      allow read, create, update, delete: if isOwner();
    }

    match /payrollPayslips/{payslipId} {
      allow read, create, update, delete: if isOwner();
    }

    // If you later split payroll profiles out of contacts:
    match /contactPayroll/{contactId} {
      allow read, create, update, delete: if isOwner();
    }

    // ---- Core accounting docs ----
    match /transactions/{id} {
      allow read: if isApproved();
      allow create, update, delete: if isManagerLike();
    }

    match /accounts/{id} {
      allow read: if isApproved();
      allow create, update, delete: if isManagerLike();
    }

    match /invoices/{id} {
      allow read: if isApproved();
      allow create, update, delete: if isApproved(); // tighten later if needed
    }

    match /purchaseInvoices/{id} {
      allow read: if isApproved();
      allow create, update, delete: if isApproved(); // tighten later if needed
    }

    match /expenses/{id} {
      allow read: if isApproved();
      allow create, update, delete: if isManagerLike();
    }

    match /projects/{id} {
      allow read: if isApproved();
      allow create, update, delete: if isManagerLike();
    }

    match /receivables/{id} {
      allow read: if isApproved();
      allow create, update, delete: if isManagerLike();
    }

    match /debts/{id} {
      allow read: if isApproved();
      allow create, update, delete: if isManagerLike();
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

